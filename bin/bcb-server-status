#!/usr/bin/env bash
set -euo pipefail

SESSION_NAME="bcb-server"
HTTP_PORT="${BCB_HTTP_PORT:-18080}"
HTTP_HOST="${BCB_HOST:-127.0.0.1}"

if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Server tmux session not found"
    exit 1
fi

if curl -sf "http://$HTTP_HOST:$HTTP_PORT/health" > /dev/null 2>&1; then
    curl -s "http://$HTTP_HOST:$HTTP_PORT/health" | python3 -m json.tool
else
    echo "Server session exists but HTTP endpoint not responding"
    exit 1
fi
